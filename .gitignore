#paste this into gitignore 

# ==========================================
# 1. NODE.JS (Frontend, Dashboard, Extension)
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
frontend/dist/
extension/dist/
dashboard/.next/
dashboard/out/

# Vite/Next.js specific
.vite/
.next/

# ==========================================
# 2. PYTHON (Backend & SDK)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Testing
.pytest_cache/
.ruff_cache/
.mypy_cache/
coverage/
.coverage
.coverage.*
nosetests.xml
pylintrc
*pyproject.toml.bak

# ==========================================
# 3. ML MODELS & VECTOR DB (ChromaDB/Transformers)
# ==========================================
# Ignore the local persistent vector store
.chroma/
backend/.chroma/
**/.chroma/

# Ignore local Hugging Face model downloads/cache if they occur in-project
.cache/
backend/.cache/
huggingface/
models/

# ==========================================
# 4. ENVIRONMENTS AND SECRETS (CRITICAL)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env*

# Firebase Credentials
serviceAccountKey*.json
**/serviceAccountKey*.json
backend/credentials/*.json
!backend/credentials/README.md

# ==========================================
# 5. IDE & SYSTEM
# ==========================================
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db