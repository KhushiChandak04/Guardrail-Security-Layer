{
  "name": "guardrail-security-layer",
  "version": "0.1.0",
  "private": true,
  "description": "Bidirectional security guardrail platform for GenAI chatbot applications.",
  "workspaces": [
    "frontend",
    "extension",
    "sdk/js"
  ],
  "scripts": {
    "dev:backend": ".venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000 --app-dir backend",
    "dev:frontend": "npm run dev --workspace @guardrail/frontend",
    "dev:extension": "npm run dev --workspace @guardrail/extension",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "security:scan": "powershell -ExecutionPolicy Bypass -File scripts/scan_secrets.ps1",
    "security:scan-history": "powershell -ExecutionPolicy Bypass -File scripts/scan_secrets.ps1 -ScanHistory"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}