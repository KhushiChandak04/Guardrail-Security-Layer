{
  "name": "guardrail-security-layer",
  "version": "0.1.0",
  "private": true,
  "description": "Bidirectional security guardrail platform for GenAI chatbot applications.",
  "workspaces": [
    "frontend",
    "extension",
    "sdk/js"
  ],
  "scripts": {
    "ports:free:backend": "powershell -ExecutionPolicy Bypass -File scripts/free_ports.ps1 -Ports 8000",
    "ports:free:frontend": "powershell -ExecutionPolicy Bypass -File scripts/free_ports.ps1 -Ports 5173",
    "predev:backend": "npm run ports:free:backend",
    "predev:backend:stable": "npm run ports:free:backend",
    "dev:backend": ".venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --reload-dir backend --host 127.0.0.1 --port 8000 --app-dir backend",
    "dev:backend:stable": ".venv\\Scripts\\python.exe -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --app-dir backend",
    "dev:frontend": "npm run dev --workspace @guardrail/frontend",
    "dev:extension": "npm run dev --workspace @guardrail/extension",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "security:scan": "powershell -ExecutionPolicy Bypass -File scripts/scan_secrets.ps1",
    "security:scan-history": "powershell -ExecutionPolicy Bypass -File scripts/scan_secrets.ps1 -ScanHistory"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "lucide-react": "^1.8.0",
    "react-chartjs-2": "^5.3.1",
    "react-router-dom": "^7.14.1"
  }
}
