APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://*

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

