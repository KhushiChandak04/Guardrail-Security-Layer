{
  "manifest_version": 3,
  "name": "Guardrail Browser Extension",
  "version": "0.1.0",
  "description": "Captures prompts and routes them through guardrail middleware.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>", "http://localhost:8000/*"],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/contentScript.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
