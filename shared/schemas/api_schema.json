{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GuardrailChatRequest",
  "type": "object",
  "properties": {
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "id_token": {
      "type": ["string", "null"]
    },
    "session_id": {
      "type": ["string", "null"]
    }
  },
  "required": ["prompt"]
}
